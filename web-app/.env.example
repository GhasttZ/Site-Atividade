# =====================================================================
# Malharia Bonfim Demo — Variáveis de Ambiente
# Copie pra .env.local e preencha. NUNCA commitar .env.local.
# =====================================================================

# ---------------------------------------------------------------------
# Supabase
# Pegue em https://supabase.com/dashboard/project/_/settings/api
# IMPORTANTE: usar as NOVAS chaves (sb_publishable_xxx / sb_secret_xxx)
# As antigas (anon / service_role) ainda funcionam até fim de 2026 mas
# estão deprecadas.
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------
# IA (OpenRouter no momento; trocável via AI_PROVIDER)
# Pegue em https://openrouter.ai/keys
# ---------------------------------------------------------------------
AI_PROVIDER=openrouter

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_PRIMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1:free
OPENROUTER_FALLBACK=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=malharia-bonfim-demo
OPENROUTER_APP_URL=https://demo.seudominio.com.br

# ---------------------------------------------------------------------
# Evolution API (WhatsApp não-oficial)
# ---------------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EVOLUTION_INSTANCE_NAME=malharia-bonfim

# ---------------------------------------------------------------------
# n8n (interno; usado por server actions que disparam workflows)
# ---------------------------------------------------------------------
N8N_BASE_URL=https://n8n.seudominio.com.br
N8N_WEBHOOK_SECRET=gere-com-openssl-rand-hex-32

# ---------------------------------------------------------------------
# Telegram (alertas de erro e handoff)
# ---------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=xxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyy
TELEGRAM_OPERATOR_CHAT_ID=-1001234567890

# ---------------------------------------------------------------------
# Tenant default (pra demo single-tenant)
# ---------------------------------------------------------------------
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
